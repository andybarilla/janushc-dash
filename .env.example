# SQLite database path. Use /app/data/janushc-dash.db in Docker.
DATABASE_URL=tmp/janushc-dash.db
PORT=8080
JWT_SECRET=change-me-in-production
JWT_EXPIRY=8h
REFRESH_TOKEN_EXPIRY=168h
CORS_ORIGIN=http://localhost:3000

# athenahealth
ATHENA_CLIENT_ID=
ATHENA_CLIENT_SECRET=
ATHENA_BASE_URL=https://api.preview.platform.athenahealth.com
ATHENA_PRACTICE_ID=195900

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_TRANSCRIBE_BUCKET=
AWS_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
TRANSCRIBE_MEDICAL_USD_PER_MINUTE=0.024
BEDROCK_INPUT_USD_PER_MILLION_TOKENS=3.00
BEDROCK_OUTPUT_USD_PER_MILLION_TOKENS=15.00

# Recording ingest script (host-side rclone + Docker Compose). Defaults shown here.
# GDRIVE_REMOTE=gdrive
# GDRIVE_RECORDINGS_PATH=Sample Recordings
# GDRIVE_SHARED_WITH_ME=true
# RECORDINGS_INBOX=recordings/inbox
# TRANSCRIPTS_DIR=tmp/transcripts
# Optional raw recording archive mirror after ingest.
# JCAWS_ARCHIVE_REMOTE=jcaws
# JCAWS_ARCHIVE_PATH=janushc/recordings/raw

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_ALLOWED_DOMAIN=janushc.com
VITE_GOOGLE_CLIENT_ID=
