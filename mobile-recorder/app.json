{
  "expo": {
    "name": "JanusHC Recorder",
    "slug": "janushc-recorder",
    "scheme": "janushcrecorder",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#666666"
    },
    "ios": {
      "bundleIdentifier": "com.janushc.recorder",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "JanusHC records visit audio so it can be transcribed and summarized for clinician review.",
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.janushc.recorder",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#666666"
      },
      "permissions": [
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MICROPHONE",
        "POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "JanusHC records visit audio so it can be transcribed and summarized for clinician review."
        }
      ],
      "@react-native-google-signin/google-signin",
      [
        "react-native-document-scanner-plugin",
        {
          "cameraPermission": "JanusHC uses the camera to scan documents for transcription and clinician review."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://dash.janushc.com",
      "googleWebClientId": "175000401230-u37jfpd36bi14555o4sb950di3kcv7r4.apps.googleusercontent.com",
      "eas": {
        "projectId": "d2cbdcc8-a9f4-4ab9-a0d2-d3863afea49b"
      }
    },
    "owner": "andybarilla"
  }
}
